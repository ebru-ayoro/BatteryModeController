<Window x:Class="BatteryModeController.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BatteryModeController"
        mc:Ignorable="d"
        Title="Battery Mode Controller" MinHeight="400" Width="520"
        WindowStartupLocation="CenterScreen" SizeToContent="Height"
        FontFamily="Segoe UI Variable Display, Segoe UI"
        Background="{DynamicResource PageBackground}">
    <Window.Resources>
        <DropShadowEffect x:Key="CardShadow" BlurRadius="16" ShadowDepth="2" Direction="270" Opacity="0.12" Color="#000000"/>
        <DropShadowEffect x:Key="ActiveCardShadow" BlurRadius="24" ShadowDepth="4" Direction="270" Opacity="0.18" Color="#000000"/>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
            <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
        </Style>

        <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{TemplateBinding Content}" FontSize="14"
                                       Foreground="{DynamicResource TextPrimary}"
                                       VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <Border Grid.Column="1" x:Name="ToggleTrack" Width="44" Height="22" CornerRadius="11"
                                    Background="{DynamicResource ToggleTrack}" BorderThickness="0" VerticalAlignment="Center">
                                <Border x:Name="ToggleThumb" Width="18" Height="18" CornerRadius="9"
                                        Background="#ffffff" HorizontalAlignment="Left" Margin="2,0,0,0"
                                        Effect="{StaticResource CardShadow}"/>
                            </Border>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CheckStates">
                                    <VisualState x:Name="Checked">
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="ToggleTrack" Storyboard.TargetProperty="Background.Color" To="{DynamicResource ToggleTrackCheckedColor}" Duration="0:0:0.2"/>
                                            <ThicknessAnimation Storyboard.TargetName="ToggleThumb" Storyboard.TargetProperty="Margin" To="24,0,0,0" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Unchecked">
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="ToggleTrack" Storyboard.TargetProperty="Background.Color" To="{DynamicResource ToggleTrackColor}" Duration="0:0:0.2"/>
                                            <ThicknessAnimation Storyboard.TargetName="ToggleThumb" Storyboard.TargetProperty="Margin" To="2,0,0,0" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PlanCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorder}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsActive}" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource ActiveCardBorder}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AccentBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentForeground}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="24,10"/>
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}" MinWidth="{TemplateBinding MinWidth}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          FocusVisualStyle="{x:Null}" ClickMode="Press"
                                          BorderThickness="0" Background="Transparent">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Border" Background="{TemplateBinding Background}"
                                                BorderBrush="{DynamicResource CardBorder}"
                                                BorderThickness="1.5" CornerRadius="6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0" Margin="10,4"
                                                                   Content="{Binding RelativeSource={RelativeSource AncestorType=ComboBox}, Path=SelectionBoxItem}"
                                                                   ContentTemplate="{Binding RelativeSource={RelativeSource AncestorType=ComboBox}, Path=SelectionBoxItemTemplate}"
                                                                   VerticalAlignment="Center"
                                                                   TextElement.Foreground="{DynamicResource TextPrimary}"/>
                                                <Border Grid.Column="1" x:Name="BtnArrow" Width="32"
                                                        Background="Transparent" CornerRadius="0,6,6,0">
                                                    <TextBlock Text="&#x25BC;" FontSize="10"
                                                               Foreground="{DynamicResource TextSecondary}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="BorderBrush"
                                                        Value="{DynamicResource ActiveCardBorder}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="Popup" IsOpen="{TemplateBinding IsDropDownOpen}"
                                   PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Bottom" Focusable="False"
                                   AllowsTransparency="True"
                                   PopupAnimation="Slide">
                                <Border Background="{DynamicResource CardBackground}"
                                        BorderBrush="{DynamicResource CardBorder}"
                                        BorderThickness="1" CornerRadius="6"
                                        Effect="{StaticResource CardShadow}"
                                        MaxHeight="300"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer>
                                        <ItemsPresenter SnapsToDevicePixels="True"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="true">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource ActiveCardBorder}"/>
                                <Setter Property="Foreground"
                                        Value="{DynamicResource AccentForeground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- STATUS CARD -->
        <Border Grid.Row="0" Style="{StaticResource Card}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border x:Name="StatusIconBg" Grid.Column="0" Width="48" Height="48" CornerRadius="24"
                        Background="#e8f5e9" Margin="0,0,16,0"
                        ToolTip="Current power source status">
                    <TextBlock x:Name="StatusIcon" Text="&#x1F50C;" FontSize="24" HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="StatusText" FontSize="20" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}">Checking...</TextBlock>
                    <TextBlock x:Name="BatteryText" FontSize="13" Foreground="{DynamicResource TextSecondary}" Margin="0,2,0,0"/>
                    <TextBlock x:Name="CurrentPlanText" FontSize="13" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MODE TOGGLE -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="20,14">
            <CheckBox x:Name="AutoModeToggle" Style="{StaticResource ToggleSwitchStyle}"
                      Content="Auto-switch"
                      ToolTip="In Auto mode, the power plan switches automatically based on whether you're plugged in or on battery"
                      Unchecked="OnModeChanged" Checked="OnModeChanged"
                      FocusVisualStyle="{x:Null}"/>
        </Border>

        <!-- PLANS CARD -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="20,20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Manual Panel -->
                <StackPanel Grid.Row="0" x:Name="ManualPanel">
                    <TextBlock Style="{StaticResource SectionLabel}">Power Plans</TextBlock>
                    <ItemsControl x:Name="PlansList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource PlanCard}">
                                    <RadioButton GroupName="PlanSelection"
                                                 IsChecked="{Binding IsActive}"
                                                 Checked="OnPlanSelected"
                                                 Tag="{Binding}"
                                                 Cursor="Hand"
                                                 ToolTip="{Binding Description}"
                                                 FocusVisualStyle="{x:Null}"
                                                 Background="Transparent"
                                                 BorderThickness="0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#x26A1;" FontSize="18" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="Medium"
                                                           Foreground="{DynamicResource TextPrimary}"/>
                                                <TextBlock Text="{Binding IsActive, Converter={x:Static local:PlanStatusConverter.Instance}}"
                                                           FontSize="11" Foreground="{DynamicResource TextSecondary}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </RadioButton>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Auto Panel -->
                <StackPanel Grid.Row="0" x:Name="AutoPanel" Visibility="Collapsed">
                    <TextBlock Style="{StaticResource SectionLabel}">Auto-Switch Settings</TextBlock>

                    <Border CornerRadius="8" BorderThickness="0" Margin="0,0,0,12"
                            Background="{DynamicResource CardBackground}"
                            Effect="{StaticResource CardShadow}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="5"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" CornerRadius="8,0,0,8"
                                    Background="{DynamicResource AcCardBorder}"/>
                            <StackPanel Grid.Column="1" Margin="16,16,16,14">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Border Width="32" Height="32" CornerRadius="16"
                                            Background="{DynamicResource AcCardBackground}"
                                            BorderBrush="{DynamicResource AcCardBorder}"
                                            BorderThickness="1"
                                            Margin="0,0,10,0">
                                        <TextBlock Text="&#x26A1;" FontSize="14" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel>
                                        <TextBlock Text="Plugged In (AC)" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimary}"/>
                                        <TextBlock Text="Power plan when connected to wall power" FontSize="11"
                                                   Foreground="{DynamicResource TextSecondary}"/>
                                    </StackPanel>
                                </StackPanel>
                                <ComboBox x:Name="AcPlanCombo" FontSize="14" MinHeight="36"
                                          DisplayMemberPath="Name"
                                          Foreground="{DynamicResource TextPrimary}"
                                          Background="{DynamicResource CardBackground}"
                                          BorderBrush="{DynamicResource CardBorder}"
                                          ToolTip="Select the power plan to use when plugged into AC power"
                                          SelectionChanged="OnAutoPlanSelectionChanged"/>
                                <TextBlock x:Name="AcPlanStatus" FontSize="11" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border CornerRadius="8" BorderThickness="0" Margin="0"
                            Background="{DynamicResource CardBackground}"
                            Effect="{StaticResource CardShadow}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="5"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" CornerRadius="8,0,0,8"
                                    Background="{DynamicResource BatCardBorder}"/>
                            <StackPanel Grid.Column="1" Margin="16,16,16,14">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Border Width="32" Height="32" CornerRadius="16"
                                            Background="{DynamicResource BatCardBackground}"
                                            BorderBrush="{DynamicResource BatCardBorder}"
                                            BorderThickness="1"
                                            Margin="0,0,10,0">
                                        <TextBlock Text="&#x1F50B;" FontSize="14" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel>
                                        <TextBlock Text="On Battery" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimary}"/>
                                        <TextBlock Text="Power plan when running on battery" FontSize="11"
                                                   Foreground="{DynamicResource TextSecondary}"/>
                                    </StackPanel>
                                </StackPanel>
                                <ComboBox x:Name="BatteryPlanCombo" FontSize="14" MinHeight="36"
                                          DisplayMemberPath="Name"
                                          Foreground="{DynamicResource TextPrimary}"
                                          Background="{DynamicResource CardBackground}"
                                          BorderBrush="{DynamicResource CardBorder}"
                                          ToolTip="Select the power plan to use when running on battery"
                                          SelectionChanged="OnAutoPlanSelectionChanged"/>
                                <TextBlock x:Name="BatteryPlanStatus" FontSize="11" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- FOOTER -->
        <Border Grid.Row="3" Style="{StaticResource Card}" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" x:Name="InfoText" FontSize="12" Foreground="{DynamicResource TextSecondary}"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="1" x:Name="ApplyBtn" Style="{StaticResource AccentButton}" Content="Apply"
                        ToolTip="Apply the selected power plan now"
                        Click="OnApplyClick" IsEnabled="False"/>
            </Grid>
        </Border>
    </Grid>
</Window>
